{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "http-server .vercel/output/static -p 4321 -s",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint \"src/**/*.{js,ts,astro}\" \"**/*.md\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,astro}\" \"**/*.md\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,astro}\" \"**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,astro}\" \"**/*.md\""
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/vercel": "10.0.2",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tailwindcss/vite": "4.2.2",
    "@vercel/speed-insights": "2.0.0",
    "astro": "6.0.8",
    "better-auth": "1.5.6",
    "pg": "8.20.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "7.5.1",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "eslint": "10.1.0",
    "eslint-plugin-astro": "1.6.0",
    "globals": "17.4.0",
    "happy-dom": "20.8.4",
    "http-server": "14.1.1",
    "jiti": "2.6.1",
    "vitest": "4.1.0"
  }
}
