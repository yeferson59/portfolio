---
import Layout from "@/layouts/Layout.astro";
import About from "@/components/sections/About.astro";
import Skills from "@/components/sections/Skills.astro";
import Metrics from "@/components/sections/Metrics.astro";
import Projects from "@/components/sections/Projects.astro";
import Services from "@/components/sections/Services.astro";
import Contact from "@/components/sections/Contact.astro";
import { developer, siteMetadata } from "@/data/site";

// Spanish version of the homepage
// Enhanced schema markup for developer and services
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteMetadata.siteUrl}#person`,
      name: developer.name,
      jobTitle: developer.title,
      description: developer.description,
      url: siteMetadata.siteUrl,
      email: developer.email,
      inLanguage: "es",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Pamplona",
        addressCountry: "Colombia",
      },
      sameAs: [
        "https://github.com/yeferson59",
        "https://www.linkedin.com/in/yeferson-toloza-42a6a7279",
        "https://x.com/yefersont59",
      ],
      knowsAbout: [
        "Desarrollo Backend",
        "Arquitectura de APIs",
        "Diseño de Bases de Datos",
        "Integración de Sistemas",
        "Optimización de Rendimiento",
        "Node.js",
        "TypeScript",
        "PostgreSQL",
        "Microservicios",
        "Docker",
      ],
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteMetadata.siteUrl}/es#service`,
      name: "Servicios de Desarrollo Backend",
      description:
        "Desarrollo backend profesional y servicios de arquitectura de APIs en Colombia",
      provider: {
        "@id": `${siteMetadata.siteUrl}#person`,
      },
      areaServed: "CO",
      serviceType: "Backend Development",
      inLanguage: "es",
    },
  ],
};
---

<Layout
  head={{
    title: "Yeferson Toloza - Desarrollador Backend",
    description:
      "Desarrollador Backend especializado en arquitectura de APIs, integración de sistemas y optimización de rendimiento en Colombia.",
    structuredData,
  }}
>
  <About />
  <Skills />
  <Metrics server:defer />
  <Projects />
  <Services />
  <Contact />
</Layout>
