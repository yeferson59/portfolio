---
import { Image } from "astro:assets";
---

<section id="about" class="section bg-white dark:bg-gray-900 py-20 md:py-32">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center mb-16" data-aos="fade-up">
            <h2 class="section-title">
                About <span class="text-gradient">Me</span>
            </h2>
            <p class="section-subtitle">
                Passionate full-stack developer with a knack for creating
                elegant solutions to complex problems.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class="relative" data-aos="fade-right">
                <!-- Profile image with decorative elements -->
                <div
                    class="relative z-10 rounded-lg overflow-hidden shadow-xl border-4 border-white dark:border-gray-800"
                >
                    <Image
                        src="https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2"
                        alt="Professional portrait"
                        class="w-full h-full object-cover"
                        inferSize
                    />
                </div>

                <!-- Decorative elements -->
                <div
                    class="absolute -top-6 -left-6 w-32 h-32 bg-primary-100 dark:bg-primary-900 rounded-lg -z-10"
                >
                </div>
                <div
                    class="absolute -bottom-6 -right-6 w-32 h-32 bg-secondary-100 dark:bg-secondary-900 rounded-lg -z-10"
                >
                </div>
            </div>

            <div data-aos="fade-left">
                <h3
                    class="text-2xl font-bold text-gray-900 dark:text-white mb-4"
                >
                    My Journey
                </h3>
                <p class="text-gray-700 dark:text-gray-300 mb-6">
                    I'm a full-stack developer with over 5 years of experience
                    building web applications that solve real-world problems. My
                    journey began with a passion for technology and a desire to
                    create digital solutions that make a difference.
                </p>
                <p class="text-gray-700 dark:text-gray-300 mb-6">
                    I specialize in JavaScript/TypeScript ecosystems, with
                    expertise in modern frameworks like React, Next.js, and
                    Node.js. I'm also proficient with database technologies and
                    have experience deploying applications to various cloud
                    platforms.
                </p>

                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div>
                        <h4
                            class="font-bold text-gray-900 dark:text-white mb-2"
                        >
                            Education
                        </h4>
                        <ul class="space-y-2">
                            <li class="text-gray-700 dark:text-gray-300">
                                🎓 Computer Science, MS
                            </li>
                            <li class="text-gray-700 dark:text-gray-300">
                                🎓 Web Development, BS
                            </li>
                        </ul>
                    </div>
                    <div>
                        <h4
                            class="font-bold text-gray-900 dark:text-white mb-2"
                        >
                            Experience
                        </h4>
                        <ul class="space-y-2">
                            <li class="text-gray-700 dark:text-gray-300">
                                👨‍💻 Senior Developer, XYZ Inc.
                            </li>
                            <li class="text-gray-700 dark:text-gray-300">
                                👨‍💻 Full-Stack Developer, ABC Ltd.
                            </li>
                        </ul>
                    </div>
                </div>

                <a href="#contact" class="btn btn-primary">Get in Touch</a>
            </div>
        </div>
    </div>
</section>
