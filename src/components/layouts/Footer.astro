---
import {
  navigationLinks,
  socialLinks,
  brand,
  meta,
  footerLinks,
} from "@/data/site";
import { getAllServices } from "@/utils/services";
import { useTranslations } from "@/i18n/ui";

const t = useTranslations(Astro.currentLocale).footer;
const tNav = useTranslations(Astro.currentLocale).nav;

// Map nav link hrefs to translated labels
const navLabelMap: Record<string, string> = {
  "#about": tNav.about,
  "#skills": tNav.skills,
  "#metrics": tNav.metrics,
  "#projects": tNav.projects,
  "#services": tNav.services,
  "#contact": tNav.contact,
};
const services = await getAllServices();
---

<footer class="footer">
  <div class="container">
    <div class="gap-xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
      <!-- Branding -->
      <div>
        <h3 class="text-accent mb-md text-2xl font-extrabold">
          {brand.tagline}
        </h3>
        <p class="text-muted mb-lg text-sm leading-relaxed">
          {brand.description}
        </p>
        <div class="gap-sm flex">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                aria-label={`Visit ${social.label} profile (opens in new tab)`}
                class="icon hover-grow"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span set:html={social.icon} aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4
          class="text-primary mb-md text-sm font-semibold tracking-wide uppercase"
        >
          {t.navigation}
        </h4>
        <ul class="space-y-xs">
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-secondary hover:text-primary gap-xs flex items-center text-sm transition-colors"
                >
                  <div class="accent-dot accent-dot--secondary" />
                  {navLabelMap[link.href] ?? link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4
          class="text-primary mb-md text-sm font-semibold tracking-wide uppercase"
        >
          {t.services}
        </h4>
        <ul class="space-y-xs">
          {
            services.map(({ data }) => (
              <li class="text-secondary hover:text-primary text-sm transition-colors">
                {data.name}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4
          class="text-primary mb-md text-sm font-semibold tracking-wide uppercase"
        >
          {t.stayUpToDate}
        </h4>
        <p class="text-secondary mb-md text-sm leading-relaxed">
          {t.subscribeDesc}
        </p>
        <form class="space-y-sm">
          <input
            type="email"
            required
            placeholder={t.subscribePlaceholder}
            class="form-input text-sm"
          />
          <button type="submit" class="btn btn--primary btn--full btn--sm">
            {t.subscribeButton}
          </button>
        </form>
        <p class="mt-sm text-muted text-xs leading-relaxed">
          {t.noSpamNote}
        </p>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div
      class="mt-xl pt-lg gap-md flex flex-col items-center justify-between border-t border-white/10 md:flex-row"
    >
      <p class="text-muted text-xs">
        {meta.copyright}
      </p>
      <div class="gap-md text-muted flex items-center text-xs">
        <a href={footerLinks.terms} class="hover:text-primary transition-colors"
          >{t.terms}</a
        >
        <a
          href={footerLinks.privacy}
          class="hover:text-primary transition-colors">{t.privacy}</a
        >
        <a
          href={footerLinks.licenses}
          class="hover:text-primary transition-colors">{t.licenses}</a
        >
      </div>
    </div>
  </div>
</footer>
