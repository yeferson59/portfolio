---
import { Image } from "astro:assets";

const projects = [
    {
        title: "E-Commerce Platform",
        description:
            "A full-featured e-commerce platform with product management, cart functionality, and secure checkout process.",
        image: "https://images.pexels.com/photos/6214476/pexels-photo-6214476.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["React", "Node.js", "MongoDB", "Stripe"],
        link: "/",
        category: "fullstack",
    },
    {
        title: "Task Management App",
        description:
            "A productivity app that helps users manage their tasks with features like categories, reminders, and progress tracking.",
        image: "https://images.pexels.com/photos/13964370/pexels-photo-13964370.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["Vue.js", "Express", "PostgreSQL"],
        link: "/",
        category: "frontend",
    },
    {
        title: "Real Estate Listings",
        description:
            "A platform for real estate agents to list properties and for buyers to search and save favorite listings.",
        image: "https://images.pexels.com/photos/7578839/pexels-photo-7578839.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["Next.js", "Tailwind CSS", "Supabase"],
        link: "/",
        category: "fullstack",
    },
    {
        title: "Weather Dashboard",
        description:
            "A weather application that provides current conditions and forecasts with a clean, intuitive interface.",
        image: "https://images.pexels.com/photos/1118873/pexels-photo-1118873.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["JavaScript", "CSS", "Weather API"],
        link: "/",
        category: "frontend",
    },
    {
        title: "Content Management System",
        description:
            "A custom CMS built for content creators with a focus on performance and ease of use.",
        image: "https://images.pexels.com/photos/4348404/pexels-photo-4348404.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["React", "GraphQL", "Node.js"],
        link: "/",
        category: "fullstack",
    },
    {
        title: "API Development",
        description:
            "RESTful API development for various client applications with comprehensive documentation.",
        image: "https://images.pexels.com/photos/546819/pexels-photo-546819.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1",
        tech: ["Node.js", "Express", "MongoDB", "Swagger"],
        link: "/",
        category: "backend",
    },
];

const categories = [
    { id: "all", label: "All Projects" },
    { id: "frontend", label: "Frontend" },
    { id: "backend", label: "Backend" },
    { id: "fullstack", label: "Full Stack" },
];
---

<section id="projects" class="section bg-white dark:bg-gray-900 py-20 md:py-32">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center mb-16" data-aos="fade-up">
            <h2 class="section-title">
                My <span class="text-gradient">Projects</span>
            </h2>
            <p class="section-subtitle">
                Here are some of the projects I've worked on. Each project
                represents a unique challenge and solution.
            </p>
        </div>

        <!-- Project filters -->
        <div class="flex justify-center mb-12" data-aos="fade-up">
            <div
                class="inline-flex flex-wrap justify-center gap-2 p-1 bg-gray-100 dark:bg-gray-800 rounded-lg"
                id="project-filters"
            >
                {
                    categories.map((category) => (
                        <button
                            class="project-filter px-4 py-2 rounded-md text-gray-700 dark:text-gray-300 font-medium transition-all"
                            data-category={category.id}
                        >
                            {category.label}
                        </button>
                    ))
                }
            </div>
        </div>

        <!-- Project grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
            id="projects-grid"
        >
            {
                projects.map((project, index) => (
                    <div
                        class="project-card card group overflow-hidden"
                        data-category={project.category}
                        data-aos="fade-up"
                        data-aos-delay={index * 100}
                    >
                        <div class="relative overflow-hidden">
                            <Image
                                src={project.image}
                                alt={project.title}
                                class="w-full h-60 object-cover object-center transform group-hover:scale-105 transition-transform duration-500"
                                inferSize
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
                                <div class="p-4 w-full">
                                    <div class="flex flex-wrap gap-2">
                                        {project.tech.map((tech) => (
                                            <span class="text-xs font-medium px-2 py-1 bg-primary/80 text-white rounded">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
                                {project.title}
                            </h3>
                            <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
                                {project.description}
                            </p>
                            <a
                                href={project.link}
                                class="inline-flex items-center text-primary dark:text-secondary font-medium"
                            >
                                View Project
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5 ml-1"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                                        clip-rule="evenodd"
                                    />
                                </svg>
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const filters = document.querySelectorAll(".project-filter");
        const projects = document.querySelectorAll(".project-card");

        // Set "All" as active by default
        const defaultFilter = document.querySelector('[data-category="all"]');
        defaultFilter?.classList.add("active");

        // Add filter functionality
        filters.forEach((filter) => {
            filter.addEventListener("click", () => {
                // Update active filter
                filters.forEach((f) => f.classList.remove("active"));
                filter.classList.add("active");

                const category = filter.getAttribute("data-category");

                // Show/hide projects based on category
                projects.forEach((project) => {
                    if (
                        category === "all" ||
                        project.getAttribute("data-category") === category
                    ) {
                        project.classList.remove("hidden");
                        project.classList.add("block");
                    } else {
                        project.classList.remove("block");
                        project.classList.add("hidden");
                    }
                });
            });
        });
    });
</script>
