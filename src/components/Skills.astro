                                        <path d="M7.5 12L12.5 9" />
                                        <path d="M12.5 15L7.5 12" />
                                    </svg>
                                )}
                                {tool.icon === "jest" && (
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-primary dark:text-secondary"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                    >
